# ─── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ───────────────────────────────────────────────
# Get from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ai-ads?retryWrites=true&w=majority

# ─── JWT / Session ───────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# ─── Google OAuth ────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── URLs ────────────────────────────────────────────────────────
# Local development
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000

# Production - uncomment and use these on Render/Vercel
# CLIENT_URL=https://fse-project-azure.vercel.app
# SERVER_URL=https://fse-project-2.onrender.com

# ─── Cloudinary ──────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── PhonePe Payment Gateway (V2 Standard Checkout) ──────────────
# Get credentials from: https://business.phonepe.com → Developer Settings
PHONEPE_CLIENT_ID=M23USBGB0JLG1_2602261033
PHONEPE_CLIENT_SECRET=Mjc3NTI3MjktZGFlZS00YzA5LWIwYjAtNTIzNDI2Mzk0MDAw
PHONEPE_CLIENT_VERSION=1
# Set to SANDBOX for testing, PRODUCTION for live
PHONEPE_ENV=SANDBOX
